# .gitignore for EcoTrack Project

# Maven
**/target/
**/pom.xml.tag
**/pom.xml.releaseBackup
**/pom.xml.versionsBackup
**/pom.xml.next
**/release.properties
**/dependency-reduced-pom.xml
**/.mvn/timing.properties
**/.mvn/wrapper/maven-wrapper.jar

# Java
*.class
*.jar
*.war
*.ear
*.log
*.ctxt
.mtj.tmp/
hs_err_pid*

# IDE
**/.idea/
**/*.iml
**/.vscode/
**/.settings/
**/.classpath
**/.project
**/.factorypath

# Node.js
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/dist/
**/.cache/

# Frontend build
**/frontend/dist/
**/frontend/.vite/

# OS
.DS_Store
Thumbs.db

# Application
**/logs/
**/application-local.yml
**/application-local.properties

# Database
**/*.db
**/*.sqlite

# Environment
.env
.env.local
